<%- include('../partials/header') %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />
<link href="https://fonts.googleapis.com/css?family=Yanone+Kaffeesatz:400,700,300" rel="stylesheet">

<style>
    .gallery-container { padding: 2rem; }
    
    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 20px;
    }

    .gallery-item {
        position: relative;
        height: 250px;
        background: #1a1a1a;
        border-radius: 8px;
        overflow: hidden;
        content-visibility: auto;
        contain-intrinsic-size: 250px;
    }

    .skeleton {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, #222 25%, #333 50%, #222 75%);
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite linear;
        z-index: 1;
    }

    @keyframes shimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    .gallery-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        cursor: pointer;
        transition: transform 0.3s ease, opacity 0.4s ease-in-out;
        opacity: 0;
        position: relative;
        z-index: 2;
        border-radius: 8px;
    }

    .gallery-img.loaded { opacity: 1; }

    .gallery-item:hover .gallery-img.loaded { transform: scale(1.05); }

    /* VIDEO INDICATOR OVERLAY */
    .video-badge {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 3;
        background: rgba(0, 0, 0, 0.4);
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid rgba(255, 255, 255, 0.8);
        pointer-events: none;
        transition: background 0.3s ease;
    }

    .gallery-item:hover .video-badge {
        background: rgba(0, 0, 0, 0.7);
    }

    .video-badge svg {
        fill: white;
        width: 30px;
        height: 30px;
        margin-left: 4px; /* Optical centering for play triangle */
    }

    .category-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 2rem;
    }

    .category-buttons .btn {
        display: inline-block;
        padding: 8px 16px;
        border: 1px solid white;
        text-decoration: none;
        color: white;
    }

    .category-buttons .btn:hover {
        background-color: white;
        color: #050505 !important; 
        border-color: white;
    }

    @media (max-width: 600px) {
        .gallery-container { padding: 1rem; }
        .category-buttons { justify-content: center; }
    }
</style>

<div class="gallery-container">
    <h2>Gallery</h2>
    
    <div class="category-buttons">
        <a href="/gallery" class="btn">All</a>
        <% categories.forEach(cat => { %>
            <a href="/gallery?cat=<%= cat.category_id %>" class="btn"><%= cat.name %></a>
        <% }) %>
    </div>

    <div class="gallery-grid">
        <% if (images && images.length === 0) { %>
            <div style="grid-column: 1 / -1; text-align: center; padding-top: 50px;">
                <h1 style="color: white; font-family: 'Yanone Kaffeesatz';">Check Back Soon</h1>
                <p style="color: rgba(255,255,255,0.7);">Fresh content is currently in the lab.</p>
            </div>
        <% } else { %>
            <% images.forEach(img => { %>
                <div class="gallery-item">
                    <div class="skeleton"></div>
                    
                    <% if (img.media_type === 'video') { %>
                        <div class="video-badge">
                            <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                        </div>
                    <% } %>

                    <a href="/gallery/<%= img.filename %>" 
                       class="glightbox" 
                       data-gallery="gallery1" 
                       data-type="<%= img.media_type === 'video' ? 'video' : 'image' %>">
                        
                        <img class="gallery-img" 
                             data-src="/gallery/<%= img.media_type === 'video' ? 'poster_' + img.filename.split('.')[0] + '.jpg' : 'thumb_' + img.filename %>" 
                             alt="<%= img.caption %>"
                             onerror="this.onerror=null; this.src='/gallery/<%= img.filename %>';">
                    </a>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
<script type="text/javascript">
    // 1. Initialize Lightbox with Video Support
    const lightbox = GLightbox({
        selector: '.glightbox',
        touchNavigation: true,
        loop: true,
        autoplayVideos: true,
        videosWidth: '1024px', // Standard theater width
    });

    // 2. Intersection Observer for Lazy Loading
    document.addEventListener("DOMContentLoaded", () => {
        const items = document.querySelectorAll('.gallery-img');
        
        const observer = new IntersectionObserver((entries, obs) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const img = entry.target;
                    const container = img.closest('.gallery-item');
                    const skeleton = container.querySelector('.skeleton');
                    
                    img.src = img.dataset.src;
                    
                    img.onload = () => {
                        img.classList.add('loaded');
                        setTimeout(() => { if(skeleton) skeleton.remove(); }, 400); 
                    };

                    obs.unobserve(img);
                }
            });
        }, { rootMargin: '200px 0px', threshold: 0.01 });

        items.forEach(img => observer.observe(img));
    });
</script>

<%- include('../partials/footer') %>