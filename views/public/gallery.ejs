<%- include('../partials/header') %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />
<link href="https://fonts.googleapis.com/css?family=Yanone+Kaffeesatz:400,700,300" rel="stylesheet">

<style>
    .gallery-container { padding: 2rem; }
    
    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 20px;
    }

    .gallery-item {
        position: relative;
        height: 250px;
        background: #1a1a1a;
        border-radius: 8px;
        overflow: hidden;
        content-visibility: auto;
        contain-intrinsic-size: 250px;
    }

    .skeleton {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, #222 25%, #333 50%, #222 75%);
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite linear;
        z-index: 1;
    }

    @keyframes shimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    .gallery-img, .gallery-video-preview {
        width: 100%;
        height: 100%;
        object-fit: cover;
        cursor: pointer;
        transition: transform 0.3s ease, opacity 0.4s ease-in-out;
        opacity: 0;
        position: relative;
        z-index: 2;
        border-radius: 8px;
    }

    .loaded { opacity: 1 !important; }

    .gallery-item:hover .loaded { transform: scale(1.05); }

    .video-badge {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 3;
        background: rgba(0, 0, 0, 0.4);
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid rgba(255, 255, 255, 0.8);
        pointer-events: none;
    }

    .video-badge svg {
        fill: white;
        width: 30px;
        height: 30px;
        margin-left: 4px;
    }

    .category-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 2rem;
    }

    .category-buttons .btn {
        display: inline-block;
        padding: 8px 16px;
        border: 1px solid white;
        text-decoration: none;
        color: white;
    }

    .category-buttons .btn:hover {
        background-color: white;
        color: #050505 !important; 
        border-color: white;
    }

    /* FIX: GLIGHTBOX STACKING CONTEXT FIXES */
    .glightbox-container {
        z-index: 999999 !important;
    }
    
    /* Force the active slide to the top so video UI doesn't leak */
    .gslide.current {
        z-index: 10 !important;
    }

    /* Ensure images have a solid background in the player */
    .gslide-image {
        background-color: #000;
    }

    /* Fix for hardware acceleration glitches on video UI */
    .gslide-video {
        backface-visibility: hidden;
        transform: translateZ(0);
        background: #000;
    }

    @media (max-width: 600px) {
        .gallery-container { padding: 1rem; }
        .category-buttons { justify-content: center; }
    }
</style>

<div class="gallery-container">
    <h2>Gallery</h2>
    
    <div class="category-buttons">
        <a href="/gallery" class="btn">All</a>
        <% categories.forEach(cat => { %>
            <a href="/gallery?cat=<%= cat.category_id %>" class="btn"><%= cat.name %></a>
        <% }) %>
    </div>

    <div class="gallery-grid">
        <% if (images && images.length === 0) { %>
            <div style="grid-column: 1 / -1; text-align: center; padding-top: 50px;">
                <h1 style="color: white; font-family: 'Yanone Kaffeesatz';">Check Back Soon</h1>
            </div>
        <% } else { %>
            <% images.forEach(img => { %>
                <div class="gallery-item">
                    <div class="skeleton"></div>
                    
                    <% if (img.media_type === 'video') { %>
                        <div class="video-badge">
                            <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                        </div>

                        <a href="/gallery/<%= img.filename %>" 
                           class="glightbox" 
                           data-gallery="gallery1" 
                           data-type="video">
                            
                            <video class="gallery-video-preview" 
                                   preload="metadata" 
                                   muted 
                                   playsinline
                                   onloadeddata="this.classList.add('loaded'); this.parentElement.parentElement.querySelector('.skeleton')?.remove();">
                                <source src="/gallery/<%= img.filename %>#t=0.1" type="video/mp4">
                            </video>
                        </a>
                    <% } else { %>
                        <a href="/gallery/<%= img.filename %>" 
                           class="glightbox" 
                           data-gallery="gallery1" 
                           data-type="image">
                            
                            <img class="gallery-img" 
                                 data-src="/gallery/thumb_<%= img.filename %>" 
                                 alt="<%= img.caption %>">
                        </a>
                    <% } %>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
<script type="text/javascript">
    const lightbox = GLightbox({
        selector: '.glightbox',
        touchNavigation: true,
        loop: true,
        autoplayVideos: true,
        videosWidth: '1024px',
    });

    // BUG FIX: Reset video opacity and pause non-active videos to prevent UI bleeding
    lightbox.on('slide_before_change', ({ prev, current }) => {
        const video = prev.instance.querySelector('video');
        if (video) {
            video.pause();
            video.style.opacity = '0'; // Hide video layer immediately
        }
    });

    lightbox.on('slide_after_change', ({ prev, current }) => {
        const video = current.instance.querySelector('video');
        if (video) {
            video.style.opacity = '1'; // Show active video layer
        }
    });

    document.addEventListener("DOMContentLoaded", () => {
        const imageElements = document.querySelectorAll('.gallery-img');
        
        const observer = new IntersectionObserver((entries, obs) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const img = entry.target;
                    const container = img.closest('.gallery-item');
                    const skeleton = container.querySelector('.skeleton');
                    
                    if(img.dataset.src) {
                        img.src = img.dataset.src;
                        img.onload = () => {
                            img.classList.add('loaded');
                            setTimeout(() => { if(skeleton) skeleton.remove(); }, 400); 
                        };
                    }
                    obs.unobserve(img);
                }
            });
        }, { rootMargin: '200px 0px', threshold: 0.01 });

        imageElements.forEach(img => observer.observe(img));
    });
</script>

<%- include('../partials/footer') %>